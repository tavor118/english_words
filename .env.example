# Google OAuth Client ID for Drive sync (optional).
# Leave unset to run the app in local-only mode.
# Get one at https://console.cloud.google.com/ — see README "Google Drive Sync" section.
VITE_GOOGLE_CLIENT_ID=

# Cambridge Dictionary API base URL (optional).
# Used for high-quality US pronunciation audio. Falls back to dictionaryapi.dev if unset or unreachable.
# Self-host from https://github.com/chenelias/cambridge-dictionary-api
VITE_CAMBRIDGE_API=

# Langeek dictionary proxy base URL (optional).
# Used as the primary image source for new words. Falls back to Wikipedia if unset or no match.
# Deploy the Cloudflare Worker in ./langeek-proxy — see README "Image source (Langeek)".
VITE_LANGEEK_API=
